        248 : DB 40                      in      A, (USARTD)     ; receive character
        24A : 21 00 20                   ld      HL, rx_queue
        24D : CD E9 01                   call    queue_add
        250 :                    isr_intr_tx:
        250 : DB 41                      in      A, (USARTS)
        252 : CB 47                      bit     ST_TxRDY_bp, A
        254 : 28 0A                      jr      Z, isr_intr_exit
        256 : 21 80 20                   ld      HL, tx_queue
        259 : CD 1A 02                   call    queue_remove
        25C : 30 07                      jr      NC, isr_intr_send_empty
        25E : D3 40                      out     (USARTD), A     ; send character
        260 :                    isr_intr_exit:
        260 : E1                         pop     HL
        261 : F1                         pop     AF
        262 : FB                         ei
        263 : ED 4D                      reti
        265 :                    isr_intr_send_empty:
        265 : 3E 36                      ld      A, RX_EN_TX_DIS
        267 : D3 41                      out     (USARTC), A     ; disable Tx
        269 : 18 F5                      jr      isr_intr_exit
