(1)     1D5 :                    ;;; -*- mode: asm; mode: flyspell-prog; -*-
(1)     1D5 :                    ;;; [queue] queue structure
(1)     1D5 : =0                 queue_len:      equ     0       ; queue length
(1)     1D5 : =1                 queue_size:     equ     1       ; buffer size
(1)     1D5 : =2                 queue_put:      equ     2       ; queue put index
(1)     1D5 : =3                 queue_get:      equ     3       ; queue get index
(1)     1D5 : =4                 queue_buf:      equ     4       ; buffer start offset
(1)     1D5 :
(1)     1D5 :                    ;;; [queue] Initialize queue
(1)     1D5 :                    ;;; @param HL queue work space pointer
(1)     1D5 :                    ;;; @param B queue work space size
(1)     1D5 :                    ;;; @clobber B
(1)     1D5 :                    queue_init:
(1)     1D5 : F5                         push    AF
(1)     1D6 : E5                         push    HL
(1)     1D7 : 36 00                      ld      (HL), 0         ; queue_len
(1)     1D9 : 78                         ld      A, B
(1)     1DA : D6 04                      sub     queue_buf
(1)     1DC : 23                         inc     HL
(1)     1DD : 77                         ld      (HL), A         ; queue_size
(1)     1DE : C6 02                      add     A, 2            ; for queue_put and queue_get
(1)     1E0 :                    queue_init_loop:
(1)     1E0 : 23                         inc     HL
(1)     1E1 : 36 00                      ld      (HL), 0
(1)     1E3 : 3D                         dec     A
(1)     1E4 : 20 FA                      jr      NZ, queue_init_loop
(1)     1E6 : E1                         pop     HL
(1)     1E7 : F1                         pop     AF
(1)     1E8 : C9                         ret
(1)     1E9 :
(1)     1E9 :                    ;;; [queue] Add an element to queue
(1)     1E9 :                    ;;; @param HL queue work space pointer
(1)     1E9 :                    ;;; @param A an element
(1)     1E9 :                    ;;; @return F.C 0 if queue is full
(1)     1E9 :                    queue_add:
(1)     1E9 : D5                         push    DE
(1)     1EA : E5                         push    HL
(1)     1EB : DD E3                      ex      (SP), IX        ; IX points queue structure
(1)     1ED : 57                         ld      D, A            ; save an element
(1)     1EE : DD 7E 00                   ld      A, (IX+queue_len)
(1)     1F1 : DD BE 01                   cp      (IX+queue_size)
(1)     1F4 : 7A                         ld      A, D               ; restore an element
(1)     1F5 : 38 05                      jr      C, queue_add_store ; queue_len < queue_size
(1)     1F7 : DD E3                      ex      (SP), IX           ; F.C=1
(1)     1F9 : E1                         pop     HL
(1)     1FA : D1                         pop     DE
(1)     1FB : C9                         ret
(1)     1FC :                    queue_add_store:
(1)     1FC : DD 34 00                   inc     (IX+queue_len)
(1)     1FF : 11 04 00                   ld      DE, queue_buf
(1)     202 : 19                         add     HL, DE
(1)     203 : DD 5E 02                   ld      E, (IX+queue_put)
(1)     206 : 19                         add     HL, DE          ; HL=&queue_buf[queue_put]
(1)     207 : 77                         ld      (HL), A         ; store an element
(1)     208 : 7B                         ld      A, E
(1)     209 : 3C                         inc     A               ; queue_put++
(1)     20A : DD BE 01                   cp      (IX+queue_size)
(1)     20D : 38 01                      jr      C, queue_add_update ; queue_put < queue_size
(1)     20F : AF                         xor     A                   ; wrap around
(1)     210 :                    queue_add_update:
(1)     210 : DD 77 02                   ld      (IX+queue_put), A
(1)     213 : 7E                         ld      A, (HL)         ; restore an element
(1)     214 : DD E3                      ex      (SP), IX
(1)     216 : E1                         pop     HL
(1)     217 : D1                         pop     DE
(1)     218 : 37                         scf                     ; set carry
(1)     219 : C9                         ret
(1)     21A :
(1)     21A :                    ;;; [queue] Remove an element from queue
(1)     21A :                    ;;; @param HL queue work space pointer
(1)     21A :                    ;;; @return A an element
(1)     21A :                    ;;; @return F.C 0 if queue is empty
(1)     21A :                    queue_remove:
(1)     21A : 7E                         ld      A, (HL)               ; queue_len
(1)     21B : B7                         or      A                     ; clear carry
(1)     21C : 20 01                      jr      NZ, queue_remove_elem ; queue_len > 0
(1)     21E : C9                         ret
(1)     21F :                    queue_remove_elem:
(1)     21F : D5                         push    DE
(1)     220 : E5                         push    HL
(1)     221 : DD E3                      ex      (SP), IX        ; IX points queue structure
(1)     223 : DD 35 00                   dec     (IX+queue_len)
(1)     226 : 11 04 00                   ld      DE, queue_buf
(1)     229 : 19                         add     HL, DE
(1)     22A : DD 5E 03                   ld      E, (IX+queue_get)
(1)     22D : 19                         add     HL, DE          ; HL=&queue_buf[queue_get]
(1)     22E : 7B                         ld      A, E
(1)     22F : 3C                         inc     A               ; queue_get++
(1)     230 : DD BE 01                   cp      (IX+queue_size)
(1)     233 : 38 01                      jr      C, queue_remove_update ; queue_get < queue_size
(1)     235 : AF                         xor     A                      ; wrap around
(1)     236 :                    queue_remove_update:
(1)     236 : DD 77 03                   ld      (IX+queue_get), A
(1)     239 : 7E                         ld      A, (HL)         ; read an element
(1)     23A : DD E3                      ex      (SP), IX
(1)     23C : E1                         pop     HL
(1)     23D : D1                         pop     DE
(1)     23E : 37                         scf                     ; set carry
(1)     23F : C9                         ret
