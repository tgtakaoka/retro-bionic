        240 :                    isr_intr:
        240 : F5                         push    AF
        241 : E5                         push    HL
        242 : DB 41                      in      A, (USARTS)
        244 : CB 4F                      bit     ST_RxRDY_bp, A
        246 : 28 08                      jr      Z, isr_intr_tx
