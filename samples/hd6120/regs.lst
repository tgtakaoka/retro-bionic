(1)       0 : =4000              FLAGS_LINK   = 04000
(1)       0 : =2000              FLAGS_GT     = 02000
(1)       0 : =1000              FLAGS_INTREQ = 01000
(1)       0 : =400               FLAGS_PWRON  = 00400
(1)       0 : =200               FLAGS_IEFF   = 00200
(1)       0 : =70                FLAGS_IF     = 00070
(1)       0 : =7                 FLAGS_DF     = 00007
          0 :                    ;;; Control panel space
          0 : =0                 PC = 0000                       ; Program counter
          0 : =1                 AC = 0001                       ; Accumulator
          0 : =2                 MQ = 0002                       ; MQ register
          0 : =3                 FLAGS = 0003                    ; AC0=Link, AC1=GT
          0 : =4                 SP1 = 0004                      ; Stack pointer 1
          0 : =5                 SP2 = 0005                      ; Stack pointer 2
          0 :
       7777 :                            *7777
       7777 : 5323                       jmp     save
      10000 :
       7723 :                            *7723
       7723 :                    save,
       7723 : 3001                       dca     AC              ; Store AC
       7724 : 7701                       acl                     ; MQ->AC
       7725 : 3002                       dca     MQ              ; Store MQ
       7726 : 6256                       gcf                     ; FLAGS->AC
       7727 : 3003                       dca     FLAGS           ; Store AC
       7730 : 6207                       rsp1                    ; SP1->AC
       7731 : 3004                       dca     SP1             ; Store SP1
       7732 : 6227                       rsp2                    ; SP2->AC
       7733 : 3005                       dca     SP2             ; Store SP2
       7734 : 5323                       jmp     save
       7735 :
       7735 :                    restore,
       7735 : 7200                       cla
       7736 : 1004                       tad     SP1             ; Load SP1
       7737 : 6217                       lsp1                    ; AC->SP1, AC=0
       7740 : 1005                       tad     SP2             ; Load SP2
       7741 : 6237                       lsp2                    ; AC->SP2, AC=0
       7742 : 1002                       tad     MQ              ; Load MQ
       7743 : 7501                       mqa                     ; AC->MQ
       7744 : 7200                       cla                     ; AC=0
       7745 : 1003                       tad     FLAGS           ; Load FLAGS
       7746 : 6005                       rtf                     ; AC->FLAGS
