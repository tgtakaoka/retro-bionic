        24E : E5                         push    HL
        24F : 21 80 20                   ld      HL, tx_queue
        252 : CD 0C 02                   call    queue_remove
        255 : E1                         pop     HL
        256 : 30 06                      jr      NC, isr_intr_send_empty
        258 : D3 40                      out     (USARTD), A     ; send character
        25A :                    isr_intr_tx_exit:
        25A : F1                         pop     AF
        25B : FB                         ei
        25C : ED 4D                      reti
        25E :                    isr_intr_send_empty:
        25E : 3E 36                      ld      A, RX_EN_TX_DIS
        260 : D3 41                      out     (USARTC), A     ; disable Tx
        262 : F1                         pop     AF
        263 : FB                         ei
        264 : ED 4D                      reti
