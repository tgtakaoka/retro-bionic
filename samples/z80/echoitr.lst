(1)     1C7 :                    ;;; -*- mode: asm; mode: flyspell-prog; -*-
(1)     1C7 :                    ;;; [queue] queue structure
(1)     1C7 : =0                 queue_len:      equ     0       ; queue length
(1)     1C7 : =1                 queue_size:     equ     1       ; buffer size
(1)     1C7 : =2                 queue_put:      equ     2       ; queue put index
(1)     1C7 : =3                 queue_get:      equ     3       ; queue get index
(1)     1C7 : =4                 queue_buf:      equ     4       ; buffer start offset
(1)     1C7 :
(1)     1C7 :                    ;;; [queue] Initialize queue
(1)     1C7 :                    ;;; @param HL queue work space pointer
(1)     1C7 :                    ;;; @param B queue work space size
(1)     1C7 :                    ;;; @clobber B
(1)     1C7 :                    queue_init:
(1)     1C7 : F5                         push    AF
(1)     1C8 : E5                         push    HL
(1)     1C9 : 36 00                      ld      (HL), 0         ; queue_len
(1)     1CB : 78                         ld      A, B
(1)     1CC : D6 04                      sub     queue_buf
(1)     1CE : 23                         inc     HL
(1)     1CF : 77                         ld      (HL), A         ; queue_size
(1)     1D0 : C6 02                      add     A, 2            ; for queue_put and queue_get
(1)     1D2 :                    queue_init_loop:
(1)     1D2 : 23                         inc     HL
(1)     1D3 : 36 00                      ld      (HL), 0
(1)     1D5 : 3D                         dec     A
(1)     1D6 : 20 FA                      jr      NZ, queue_init_loop
(1)     1D8 : E1                         pop     HL
(1)     1D9 : F1                         pop     AF
(1)     1DA : C9                         ret
(1)     1DB :
(1)     1DB :                    ;;; [queue] Add an element to queue
(1)     1DB :                    ;;; @param HL queue work space pointer
(1)     1DB :                    ;;; @param A an element
(1)     1DB :                    ;;; @return F.C 0 if queue is full
(1)     1DB :                    queue_add:
(1)     1DB : D5                         push    DE
(1)     1DC : E5                         push    HL
(1)     1DD : DD E3                      ex      (SP), IX        ; IX points queue structure
(1)     1DF : 57                         ld      D, A            ; save an element
(1)     1E0 : DD 7E 00                   ld      A, (IX+queue_len)
(1)     1E3 : DD BE 01                   cp      (IX+queue_size)
(1)     1E6 : 7A                         ld      A, D               ; restore an element
(1)     1E7 : 38 05                      jr      C, queue_add_store ; queue_len < queue_size
(1)     1E9 : DD E3                      ex      (SP), IX           ; F.C=1
(1)     1EB : E1                         pop     HL
(1)     1EC : D1                         pop     DE
(1)     1ED : C9                         ret
(1)     1EE :                    queue_add_store:
(1)     1EE : DD 34 00                   inc     (IX+queue_len)
(1)     1F1 : 11 04 00                   ld      DE, queue_buf
(1)     1F4 : 19                         add     HL, DE
(1)     1F5 : DD 5E 02                   ld      E, (IX+queue_put)
(1)     1F8 : 19                         add     HL, DE          ; HL=&queue_buf[queue_put]
(1)     1F9 : 77                         ld      (HL), A         ; store an element
(1)     1FA : 7B                         ld      A, E
(1)     1FB : 3C                         inc     A               ; queue_put++
(1)     1FC : DD BE 01                   cp      (IX+queue_size)
(1)     1FF : 38 01                      jr      C, queue_add_update ; queue_put < queue_size
(1)     201 : AF                         xor     A                   ; wrap around
(1)     202 :                    queue_add_update:
(1)     202 : DD 77 02                   ld      (IX+queue_put), A
(1)     205 : 7E                         ld      A, (HL)         ; restore an element
(1)     206 : DD E3                      ex      (SP), IX
(1)     208 : E1                         pop     HL
(1)     209 : D1                         pop     DE
(1)     20A : 37                         scf                     ; set carry
(1)     20B : C9                         ret
(1)     20C :
(1)     20C :                    ;;; [queue] Remove an element from queue
(1)     20C :                    ;;; @param HL queue work space pointer
(1)     20C :                    ;;; @return A an element
(1)     20C :                    ;;; @return F.C 0 if queue is empty
(1)     20C :                    queue_remove:
(1)     20C : 7E                         ld      A, (HL)               ; queue_len
(1)     20D : B7                         or      A                     ; clear carry
(1)     20E : 20 01                      jr      NZ, queue_remove_elem ; queue_len > 0
(1)     210 : C9                         ret
(1)     211 :                    queue_remove_elem:
(1)     211 : D5                         push    DE
(1)     212 : E5                         push    HL
(1)     213 : DD E3                      ex      (SP), IX        ; IX points queue structure
(1)     215 : DD 35 00                   dec     (IX+queue_len)
(1)     218 : 11 04 00                   ld      DE, queue_buf
(1)     21B : 19                         add     HL, DE
(1)     21C : DD 5E 03                   ld      E, (IX+queue_get)
(1)     21F : 19                         add     HL, DE          ; HL=&queue_buf[queue_get]
(1)     220 : 7B                         ld      A, E
(1)     221 : 3C                         inc     A               ; queue_get++
(1)     222 : DD BE 01                   cp      (IX+queue_size)
(1)     225 : 38 01                      jr      C, queue_remove_update ; queue_get < queue_size
(1)     227 : AF                         xor     A                      ; wrap around
(1)     228 :                    queue_remove_update:
(1)     228 : DD 77 03                   ld      (IX+queue_get), A
(1)     22B : 7E                         ld      A, (HL)         ; read an element
(1)     22C : DD E3                      ex      (SP), IX
(1)     22E : E1                         pop     HL
(1)     22F : D1                         pop     DE
(1)     230 : 37                         scf                     ; set carry
(1)     231 : C9                         ret
