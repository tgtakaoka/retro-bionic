(1)    21A1 : B0 1A 1E                   ldb     DE, A           ; save an element
(1)    21A4 : B2 1C 1A                   ldb     A, queue_len[HL]
(1)    21A7 : 9B 1C 01 1A                cmpb    A, queue_size[HL]
(1)    21AB : B0 1E 1A                   ldb     A, DE              ; restore an element
