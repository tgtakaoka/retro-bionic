(1)    2177 :                    ;;; -*- mode: asm; mode: flyspell-prog; -*-
(1)    2177 :                    ;;; [queue] queue structure
(1)    2177 : =0                 queue_len:      equ     0       ; queue length
(1)    2177 : =1                 queue_size:     equ     1       ; buffer size
