(1)       0 : =10                CTSF_bm         =     00001000B / Clear To Send Flag
(1)       0 : =20                FERR_bm         =     00010000B / Frame Error Flag
(1)       0 : =40                OVRN_bm         =     00100000B / Receiver Overrun Flag
(1)       0 : =100               PERR_bm         =     01000000B / Parity Error Flag
