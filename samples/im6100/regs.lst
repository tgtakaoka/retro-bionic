          0 :                    ;;; -*- mode: asm; mode: flyspell-prog; -*-
          0 :                            include "im6100.inc"
(1)       0 :                    ;;; -*- mode: asm; mode: flyspell-prog; -*-
(1)       0 :                            cpu     6100
(1)       0 :                            option  implicit-word, on
(1)       0 :                    ;;; FLAGS; RTF, GTF
(1)       0 : =4000              FLAGS_LINK   = 04000
(1)       0 : =1000              FLAGS_INTREQ = 01000
(1)       0 : =200               FLAGS_IEFF   = 00200
          0 :                    ;;; Control panel space
          0 : =0                 PC = 0000                       ; Program counter
          0 : =1                 AC = 0001                       ; Accumulator
          0 : =2                 MQ = 0002                       ; MQ register
          0 : =3                 FLAGS = 0003                    ; AC0=Link, AC1=GT
          0 :
       7777 :                            *7777
       7777 : 5323                       jmp     save
      10000 :
       7723 :                            *7723
       7723 :                    save,
       7723 : 3001                       dca     AC              ; Store AC
       7724 : 7701                       acl                     ; MQ->AC
       7725 : 3002                       dca     MQ              ; Store MQ
       7726 : 6004                       gtf                     ; FLAGS->AC
       7727 : 3003                       dca     FLAGS           ; Store AC
       7730 : 5323                       jmp     save
       7731 :
       7731 :                    restore,
       7731 : 7200                       cla
       7732 : 1002                       tad     MQ              ; Load MQ
       7733 : 7501                       mqa                     ; AC->MQ
       7734 : 7200                       cla                     ; AC=0
       7735 : 1003                       tad     FLAGS           ; Load FLAGS
       7736 : 6005                       rtf                     ; AC->FLAGS
       7737 : 7200                       cla                     ; AC=0
       7740 : 1001                       tad     AC              ; Load AC
       7741 : 5400                       jmp     I PC            ; Jump to IF:PC
