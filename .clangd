# -*- mode: yaml; mode: flyspell-prog; -*-
# Includes/defines come from compile_commands.json (run `make compiledb`).

# Fragment 1 (headers only): the project uses .h for C++ headers, so force C++.
If:
  PathMatch: .*\.h
CompileFlags:
  Add: [-xc++]

---
# Fragment 2 (all files):
Diagnostics:
  ClangTidy:
    Remove:
      # suppress ExtendedClass::parentClassMethod
      - readability-qualified-auto
  # clang uses its own <stdint.h> (int32_t = int), while newlib's stdlib.h
  # declares `long random(void)` and Teensy's WProgram.h `int32_t random(void)`.
  # Harmless clang-vs-gcc mismatch in system headers, not our code.
  Suppress: [ovl_diff_return_type]
